# =============================================================================
# VANCE — Environment Variables
# Copy to .env and fill in all values before running.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# ANTHROPIC / LLM
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_RETRY_BASE_DELAY_S=1.0


# -----------------------------------------------------------------------------
# ORCHESTRATOR
# -----------------------------------------------------------------------------
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=7700
ORCHESTRATOR_SECRET_KEY=
ORCHESTRATOR_QUEUE_MAX_SIZE=500
ORCHESTRATOR_HEARTBEAT_INTERVAL_S=30


# -----------------------------------------------------------------------------
# VOICE
# -----------------------------------------------------------------------------
VOICE_WAKE_WORD=hey-vance
VOICE_STT_PROVIDER=whisper          # whisper | deepgram
VOICE_DEEPGRAM_API_KEY=
VOICE_INPUT_DEVICE_INDEX=0
VOICE_CONFIDENCE_THRESHOLD=0.75


# -----------------------------------------------------------------------------
# REDIS (session state + task queue)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_SESSION=0
REDIS_DB_QUEUE=1
REDIS_TTL_SESSION_S=86400


# -----------------------------------------------------------------------------
# POSTGRES
# -----------------------------------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vance
POSTGRES_USER=vance
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}


# -----------------------------------------------------------------------------
# WIREGUARD (tunnel local <-> VPS)
# -----------------------------------------------------------------------------
WG_INTERFACE=wg0
WG_LOCAL_PRIVATE_KEY=
WG_LOCAL_ADDRESS=10.10.0.1/24
WG_VPS_PUBLIC_KEY=
WG_VPS_ENDPOINT=<contabo-vps-ip>:51820
WG_VPS_ALLOWED_IPS=10.10.0.0/24
WG_KEEPALIVE_S=25


# -----------------------------------------------------------------------------
# CONTABO VPS
# -----------------------------------------------------------------------------
VPS_HOST=10.10.0.2           # WireGuard IP of VPS
VPS_SSH_USER=vance
VPS_SSH_KEY_PATH=~/.ssh/vance_vps


# -----------------------------------------------------------------------------
# AGENT: MARKETING
# -----------------------------------------------------------------------------
MARKETING_AGENT_HOST=10.10.0.2
MARKETING_AGENT_PORT=8100
MARKETING_AGENT_SECRET=


# -----------------------------------------------------------------------------
# AGENT: OUTREACH
# -----------------------------------------------------------------------------
OUTREACH_AGENT_HOST=10.10.0.2
OUTREACH_AGENT_PORT=8101
OUTREACH_AGENT_SECRET=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
OUTREACH_REPLY_POLL_INTERVAL_S=300


# -----------------------------------------------------------------------------
# AGENT: ANALYTICS
# -----------------------------------------------------------------------------
ANALYTICS_AGENT_HOST=10.10.0.2
ANALYTICS_AGENT_PORT=8102
ANALYTICS_AGENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com


# -----------------------------------------------------------------------------
# AGENT: DEV
# -----------------------------------------------------------------------------
DEV_AGENT_HOST=10.10.0.2
DEV_AGENT_PORT=8103
DEV_AGENT_SECRET=
GITHUB_TOKEN=
GITHUB_ORG=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
CLAUDE_CODE_BIN=/usr/local/bin/claude


# -----------------------------------------------------------------------------
# AGENT: SECURITY
# -----------------------------------------------------------------------------
SECURITY_AGENT_HOST=10.10.0.2
SECURITY_AGENT_PORT=8104
SECURITY_AGENT_SECRET=
SECURITY_UPTIME_TARGETS=https://starpio.com,https://localoutrank.com
SECURITY_ALERT_EMAIL=
SECURITY_CHECK_INTERVAL_S=60


# -----------------------------------------------------------------------------
# MAILCOW (pre-installed on VPS)
# -----------------------------------------------------------------------------
MAILCOW_HOST=10.10.0.2
MAILCOW_API_KEY=
MAILCOW_DOMAIN=
MAILCOW_SMTP_PORT=587
MAILCOW_SMTP_USER=
MAILCOW_SMTP_PASSWORD=


# -----------------------------------------------------------------------------
# WEBHOOKS
# -----------------------------------------------------------------------------
WEBHOOKS_PORT=3001
WEBHOOKS_SECRET=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# DASHBOARD (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
DASHBOARD_PORT=3000


# -----------------------------------------------------------------------------
# FORGE AGENT — cold outreach engine
# -----------------------------------------------------------------------------
FORGE_API_URL=http://localhost:8900
FORGE_API_SECRET=               # shared secret for Forge internal API

FORGE_PIXEL_SERVER_URL=         # e.g. http://your-vps-ip:8901  (tracking pixel endpoint)

# JSON array: [{"email":"me@domain.com","password":"...","display_name":"John"}]
FORGE_SENDER_POOL=[]

# JSON array: [{"email":"seed@gmail.com","password":"...","imap_host":"imap.gmail.com","name":"Seed"}]
FORGE_SEED_LIST=[]

# Enrichment — free tiers (Apollo: 50/mo, Hunter: 25/mo)
FORGE_APOLLO_API_KEY=
FORGE_HUNTER_API_KEY=

# Path to saved LinkedIn session cookies (JSON export from browser)
FORGE_LINKEDIN_COOKIES_PATH=/app/.linkedin_cookies.json


# -----------------------------------------------------------------------------
# GOOGLE PLACES API (free tier: 28,500 calls/month)
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=


# -----------------------------------------------------------------------------
# BACKBLAZE B2 (S3-compatible storage, ~$6/TB)
# Endpoint format: https://s3.{region}.backblazeb2.com
# -----------------------------------------------------------------------------
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT_URL=
B2_BUCKET_NAME=vance-reports


# -----------------------------------------------------------------------------
# LOCAL RANK GRADER
# GRADER_TRACKER_URL: public base URL where the webhooks service is exposed
#   (e.g. https://tracker.localrankgrader.com). Used for open pixels and click tracking.
# GRADER_SEO_OUTPUT_DIR: local directory for generated SEO JSON page specs.
# -----------------------------------------------------------------------------
GRADER_TRACKER_URL=
GRADER_SEO_OUTPUT_DIR=/tmp/grader_seo_pages
LOCALOUTRANK_TRIAL_URL=https://localoutrank.ai/trial


# -----------------------------------------------------------------------------
# CELERY (background tasks + cron beat)
# Uses Redis DB 2 (broker) and DB 3 (results) — separate from session/queue
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/2
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/3


# -----------------------------------------------------------------------------
# SEARXNG (web research — replaces SerpAPI)
# -----------------------------------------------------------------------------
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET_KEY=             # random 32+ char string


# -----------------------------------------------------------------------------
# IMAGE GENERATION
# IMAGE_BACKEND=comfyui uses self-hosted GPU (set when GPU machine is available)
# IMAGE_BACKEND=replicate uses pay-per-use API (default interim)
# -----------------------------------------------------------------------------
IMAGE_BACKEND=replicate
REPLICATE_API_TOKEN=
COMFYUI_URL=http://localhost:8188


# -----------------------------------------------------------------------------
# FEATURE FLAGS — Unleash (replaces LaunchDarkly)
# -----------------------------------------------------------------------------
UNLEASH_URL=http://unleash:4242/api
UNLEASH_API_TOKEN=              # create in Unleash admin UI


# -----------------------------------------------------------------------------
# TWENTY CRM (replaces HubSpot / GoHighLevel for internal use)
# -----------------------------------------------------------------------------
TWENTY_CRM_URL=http://twenty:3000
TWENTY_CRM_API_KEY=             # create in Twenty settings → API keys


# -----------------------------------------------------------------------------
# MONITORING — Grafana + Prometheus + Loki (replaces Datadog/New Relic)
# These run in docker-compose.tools.yml — see scripts/setup_tools.sh
# -----------------------------------------------------------------------------
GRAFANA_URL=http://localhost:3010
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=http://localhost:3010
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100


# -----------------------------------------------------------------------------
# UPTIME KUMA (replaces PagerDuty for uptime alerting)
# -----------------------------------------------------------------------------
UPTIME_KUMA_URL=http://localhost:3001


# -----------------------------------------------------------------------------
# OUTLINE (wiki / knowledge base — replaces Notion/Confluence)
# -----------------------------------------------------------------------------
OUTLINE_URL=http://localhost:3030
OUTLINE_PUBLIC_URL=http://localhost:3030
OUTLINE_API_TOKEN=              # create in Outline settings → API tokens
OUTLINE_SECRET_KEY=             # random 32+ char string
OUTLINE_UTILS_SECRET=           # random 32+ char string


# -----------------------------------------------------------------------------
# UMAMI (web analytics — replaces GA on owned properties)
# Default credentials: admin / umami — change on first login
# -----------------------------------------------------------------------------
UMAMI_URL=http://localhost:3020
UMAMI_WEBSITE_ID=               # copy from Umami settings after adding a website
UMAMI_HASH_SALT=                # random string (used to anonymise IPs)


# -----------------------------------------------------------------------------
# TOOLS STACK INFRASTRUCTURE (used only by docker-compose.tools.yml)
# -----------------------------------------------------------------------------
TOOLS_POSTGRES_PASSWORD=
TOOLS_REDIS_PASSWORD=


# -----------------------------------------------------------------------------
# TWENTY CRM INTERNAL (docker-compose.tools.yml only)
# -----------------------------------------------------------------------------
TWENTY_SERVER_URL=http://localhost:3040
TWENTY_FRONT_URL=http://localhost:3040
TWENTY_APP_SECRET=              # random 32+ char string


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                 # json | text
LOG_DIR=/var/log/vance


# =============================================================================
# INTEGRATION AGENT — external service connectors
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Railway
# -----------------------------------------------------------------------------
RAILWAY_API_TOKEN=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=                   # e.g. https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=           # the xxxx part of your Supabase URL

# -----------------------------------------------------------------------------
# Square
# -----------------------------------------------------------------------------
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=production   # production | sandbox

# -----------------------------------------------------------------------------
# QuickBooks Online (OAuth2 refresh token — generate via developer.intuit.com)
# -----------------------------------------------------------------------------
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=                    # Company ID shown in QBO URL
QB_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Google OAuth2 — shared credentials for all Google services below
# Create at console.cloud.google.com → APIs & Services → Credentials
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Workspace (Gmail, Drive, Docs) — one refresh token per service account
GOOGLE_WORKSPACE_REFRESH_TOKEN=

# Google Analytics 4
GA4_PROPERTY_ID=                # numeric property ID (not measurement ID)
GA4_REFRESH_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=         # hyphenated format: 123-456-7890

# Google Business Profile
GBP_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Meta Ads (Facebook / Instagram)
# Generate a long-lived user access token at developers.facebook.com
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=             # numeric only — the act_ prefix is added automatically

# -----------------------------------------------------------------------------
# Twilio
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # E.164 format: +15551234567

# -----------------------------------------------------------------------------
# Calendly
# -----------------------------------------------------------------------------
CALENDLY_API_TOKEN=
